# ═══════════════════════════════════════════════════════════════
# .env.example — Variables de entorno requeridas para Gypi
# Copiar a .env.local y completar con los valores reales.
# Nunca commitear .env.local al repositorio.
# ═══════════════════════════════════════════════════════════════


# ─── Supabase ───────────────────────────────────────────────────
# URL del proyecto Supabase (también usada en el cliente para Realtime)
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (solo para Realtime en el cliente — NO tiene acceso a datos con RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service key (backend only — bypasea RLS, NUNCA exponer al cliente)
SUPABASE_SERVICE_KEY=


# ─── Auth JWT ───────────────────────────────────────────────────
# Secret para firmar access + refresh tokens (mínimo 32 caracteres)
JWT_SECRET=


# ─── Google OAuth ("Continuar con Google") ──────────────────────
# Se generan en https://console.cloud.google.com/apis/credentials
# (Create credentials → OAuth client ID → Web application).
# El Authorized redirect URI debe ser exactamente:
#   ${NEXT_PUBLIC_APP_URL}/api/auth/google/callback
# tanto para producción (https://gypi.app/api/auth/google/callback) como
# para desarrollo local (http://localhost:3000/api/auth/google/callback) —
# agregar ambos como URIs autorizados en el mismo client ID.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── MercadoPago ────────────────────────────────────────────────
# Access token de la aplicación de MP (producción o sandbox)
MERCADOPAGO_ACCESS_TOKEN=

# Secret para validar la firma HMAC de los webhooks de MP
MERCADOPAGO_WEBHOOK_SECRET=


# ─── Firebase (push notifications) ──────────────────────────────
# Configuración pública del proyecto Firebase (segura en cliente)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# VAPID key para Web Push (se obtiene en Firebase Console > Cloud Messaging)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Service account del proyecto Firebase para el backend (elegir UNA opción):
# Opción A — JSON directo (recomendado para desarrollo local):
FIREBASE_SERVICE_ACCOUNT=
# Opción B — JSON codificado en base64 (recomendado para Vercel, evita problemas con saltos de línea):
FIREBASE_SERVICE_ACCOUNT_B64=


# ─── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=

# Dirección "from" para los emails transaccionales (ej: noreply@gypi.app)
RESEND_FROM=

# Secret (Svix) para validar la firma del webhook de Resend
# (Resend Dashboard > Webhooks > Signing Secret, empieza con "whsec_")
RESEND_WEBHOOK_SECRET=

# Email interno que recibe las consultas del formulario "Contactanos" de
# Enterprise (opcional — default: contacto@gypi.app)
ENTERPRISE_CONTACT_EMAIL=


# ─── Superadmin ─────────────────────────────────────────────────
# Secret para autenticar el panel de superadmin en /superadmin
SUPERADMIN_SECRET=


# ─── Cron jobs (Vercel) ─────────────────────────────────────────
# Secret para proteger los endpoints /api/cron/* de llamadas no autorizadas
CRON_SECRET=


# ─── Claude / Anthropic (chat IA y reportes) ────────────────────
ANTHROPIC_API_KEY=

# Modelo a usar (opcional — default: claude-haiku-4-5-20251001)
# Opciones: claude-haiku-4-5-20251001 | claude-sonnet-4-6 | claude-opus-4-8
ANTHROPIC_MODEL=


# ─── App ─────────────────────────────────────────────────────────
# URL base pública de la app (sin trailing slash).
# Usada en emails de verificación, links de invitación, etc.
# Producción: https://gypi.app  |  Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=


# ─── Facturación electrónica ARCA / ex-AFIP (Factura C, monotributo) ─
# Sin AFIP_ACCESS_TOKEN, app/lib/afip.js no hace nada (kill-switch) y
# ningún pago se ve afectado — la activación del plan nunca depende de esto.
#
# 1. AFIP_ACCESS_TOKEN: gratis, se obtiene creando una cuenta en
#    https://app.afipsdk.com. Con SOLO esto ya se puede probar el flujo
#    completo contra el CUIT público de pruebas de ARCA (sin certificado).
AFIP_ACCESS_TOKEN=

# 2. Para emitir facturas reales (no de prueba), completar los 3 de abajo.
#    Se generan en ARCA (arca.gob.ar) con tu Clave Fiscal nivel 3:
#    Administrador de Relaciones de Clave Fiscal → adherir al servicio
#    "wsfe" (Factura Electrónica) → Administración de Certificados
#    Digitales → generar certificado (.crt) y su clave privada (.key).
AFIP_CUIT=
AFIP_CERT=
AFIP_KEY=

# Punto de venta habilitado en ARCA para facturar (opcional, default 1)
AFIP_PUNTO_VENTA=


# ─── Google AdSense (publicidad, solo plan Free) ────────────────
# Sin estas dos, app/components/AdSlot.jsx no renderiza nada (kill-switch).
# Publisher ID de la cuenta de AdSense (ej: ca-pub-1234567890123456).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Id del bloque de anuncio creado en AdSense para el dashboard gerencial.
NEXT_PUBLIC_ADSENSE_SLOT_DASHBOARD=


# ─── Sentry (monitoreo de errores) ──────────────────────────────
# DSN del proyecto Sentry. Obtenerlo en sentry.io > Settings > Client Keys.
# NEXT_PUBLIC_ expone el DSN al cliente para capturar errores de browser.
# La variable sin prefijo se usa en el servidor (API routes, SSR).
# Si no se configuran, Sentry queda desactivado silenciosamente.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Requerido solo para subir source maps en CI/CD (opcional en desarrollo local)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
