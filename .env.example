# ═══════════════════════════════════════════════════════════════
# .env.example — Variables de entorno requeridas para Gypi
# Copiar a .env.local y completar con los valores reales.
# Nunca commitear .env.local al repositorio.
# ═══════════════════════════════════════════════════════════════


# ─── Supabase ───────────────────────────────────────────────────
# URL del proyecto Supabase (también usada en el cliente para Realtime)
NEXT_PUBLIC_SUPABASE_URL=

# Anon key (solo para Realtime en el cliente — NO tiene acceso a datos con RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service key (backend only — bypasea RLS, NUNCA exponer al cliente)
SUPABASE_SERVICE_KEY=


# ─── Auth JWT ───────────────────────────────────────────────────
# Secret para firmar access + refresh tokens (mínimo 32 caracteres)
JWT_SECRET=


# ─── MercadoPago ────────────────────────────────────────────────
# Access token de la aplicación de MP (producción o sandbox)
MERCADOPAGO_ACCESS_TOKEN=

# Secret para validar la firma HMAC de los webhooks de MP
MERCADOPAGO_WEBHOOK_SECRET=


# ─── Firebase (push notifications) ──────────────────────────────
# Configuración pública del proyecto Firebase (segura en cliente)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# VAPID key para Web Push (se obtiene en Firebase Console > Cloud Messaging)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Service account del proyecto Firebase (JSON en base64, para el backend)
FIREBASE_SERVICE_ACCOUNT_B64=


# ─── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=

# Dirección "from" para los emails transaccionales (ej: noreply@gypi.app)
RESEND_FROM=


# ─── Superadmin ─────────────────────────────────────────────────
# Secret para autenticar el panel de superadmin en /superadmin
SUPERADMIN_SECRET=


# ─── Cron jobs (Vercel) ─────────────────────────────────────────
# Secret para proteger los endpoints /api/cron/* de llamadas no autorizadas
CRON_SECRET=


# ─── Claude / Anthropic (chat IA y reportes) ────────────────────
ANTHROPIC_API_KEY=
